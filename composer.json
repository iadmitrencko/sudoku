{
    "name": "sudoku/sudoku",
    "type": "project",
    "require": {
        "php": "^8.4",
        "symfony/console": "^7.2",
        "symfony/framework-bundle": "^8.0",
        "symfony/dotenv": "^8.0",
        "symfony/yaml": "^8.0",
        "symfony/twig-bundle": "^8.0",
        "twig/twig": "^3.23"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "fakerphp/faker": "^1.24"
    },
    "autoload": {
        "psr-4": {
            "Sudoku\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sudoku\\Tests\\": "tests/"
        }
    }
}
